# ⛽ FuelWatch — Configuration
# Скопируй этот файл в .env и заполни свои значения:
#   cp .env.example .env

# ─────────────────────────────
# 📦 Database (PostgreSQL)
# ─────────────────────────────
DATABASE_URL=postgresql+asyncpg://fuelwatch:fuelwatch_pass@localhost:5432/fuelwatch
DATABASE_URL_SYNC=postgresql://fuelwatch:fuelwatch_pass@localhost:5432/fuelwatch

# ─────────────────────────────
# 🗄️ Redis
# ─────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────
# 🔐 JWT Authentication
# ─────────────────────────────
JWT_SECRET_KEY=super-secret-key-change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────
# ⏳ Celery (фоновые задачи)
# ─────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─────────────────────────────
# 🤖 Telegram Bot
# ─────────────────────────────
# Получить токен: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# ─────────────────────────────
# 📊 Парсинг цен
# ─────────────────────────────
PARSE_INTERVAL_HOURS=4
